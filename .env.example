# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audit_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Neon Database (optional - choose one database provider)
NEON_CONNECTION_STRING=postgresql://username:password@host/neondb?sslmode=require

# LLM Provider - Choose ONE (Google recommended)
# SARVAM_API_KEY=sk_your_sarvam_api_key
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Override AI provider (default: gemini)
# Options: gemini, openai, anthropic, local
AI_PROVIDER=gemini

# Optional: Use local LLM instead of cloud (default: false)
USE_LOCAL_LLM=true
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_API_KEY=llama.cpp
LOCAL_LLM_MODEL=gemma-4-E2B-it-Q4_K_M.gguf

# Optional: OpenAI / Anthropic API keys (if using those providers)
# OPENAI_API_KEY=sk_your_openai_key
# ANTHROPIC_API_KEY=sk-ant_your_anthropic_key

# LangChain Tracing (optional - useful for debugging)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key
LANGCHAIN_PROJECT=ai-audit-rag-2026

# PostgreSQL Settings (for Vendor Payment Anomaly Detector)
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=audit_db
PG_USER=postgres
PG_PASSWORD=your_password_here